{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "public": true,
  "buildCommand": "./scripts/vercel-build.sh",
  "outputDirectory": "web",
  "redirects": [
    { "source": "/", "destination": "/briefing" },
    { "source": "/routes", "destination": "/briefing" },
    { "source": "/routes/", "destination": "/briefing" },
    { "source": "/routes/index", "destination": "/briefing" },
    { "source": "/routes/index.html", "destination": "/briefing" },
    { "source": "/routes/game", "destination": "/game" },
    { "source": "/routes/game.html", "destination": "/game" },
    { "source": "/routes/status", "destination": "/status" },
    { "source": "/routes/status.html", "destination": "/status" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ]
}
